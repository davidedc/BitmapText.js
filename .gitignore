
.DS_Store
.aider*

# Node.js dependencies
node_modules/

# Built/bundled demo files (generated by build scripts)
examples/node/dist/
.vscode/settings.json

# Generated output files (screenshots, renders, test files)
screenshot-*.png
hello-world-output.png
hello-world-multi-size-output.png
test-simple.html
test-simple.png
aa-rebuild-output/

# font-assets/ contents are distributed via GitHub Releases (see font-assets/README.md).
# Only the directory marker + README are tracked; the asset bytes are not.
font-assets/*
!font-assets/.gitkeep
!font-assets/README.md
